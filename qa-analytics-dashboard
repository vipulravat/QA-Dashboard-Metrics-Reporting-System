CREATE TABLE test_execution (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    execution_date DATE,
    total_tests INT,
    passed_tests INT,
    failed_tests INT,
    skipped_tests INT
);


CREATE TABLE defects (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    defect_key VARCHAR(50),
    severity VARCHAR(20),
    status VARCHAR(20),
    created_date DATE,
    closed_date DATE
);


CREATE TABLE releases (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    release_name VARCHAR(100),
    release_date DATE,
    production_incidents INT
);

@Entity
@Table(name="test_execution")
public class TestExecution {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private LocalDate executionDate;

    private Integer totalTests;

    private Integer passedTests;

    private Integer failedTests;

    private Integer skippedTests;
}

@Repository
public interface TestExecutionRepository
        extends JpaRepository<TestExecution, Long> {
}

@Service
@RequiredArgsConstructor
public class MetricsService {

    private final TestExecutionRepository repository;

    public double calculatePassRate() {

        List<TestExecution> executions =
                repository.findAll();

        int total =
                executions.stream()
                .mapToInt(TestExecution::getTotalTests)
                .sum();

        int passed =
                executions.stream()
                .mapToInt(TestExecution::getPassedTests)
                .sum();

        return ((double) passed / total) * 100;
    }
}

@RestController
@RequestMapping("/metrics")
@RequiredArgsConstructor
public class MetricsController {

    private final MetricsService service;

    @GetMapping("/pass-rate")
    public Double passRate() {
        return service.calculatePassRate();
    }
}

